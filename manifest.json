{
  "manifest_version": 3,
  "name": "CourseMate (Test)",
  "short_name": "CourseMate",
  "version": "1.0.0",
  "description": "Test build: RateMyProfessors ratings on course registration pages for UH, UNT, UTSA, UT Austin, UT Dallas, Texas Southern, Texas State, and CollegeScheduler.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.uh.edu/*",
    "https://*.unt.edu/*",
    "https://*.utsa.edu/*",
    "https://*.utexas.edu/*",
    "https://*.utdallas.edu/*",
    "https://utdallas.collegescheduler.com/*",
    "https://*.tsu.edu/*",
    "https://*.ec.tsu.edu/*",
    "https://reg-prod.ec.tsu.edu/*",
    "https://*.txstate.edu/*",
    "https://*.ec.txstate.edu/*",
    "https://reg-prod.ec.txstate.edu/*",
    "https://txstate.collegescheduler.com/*",
    "https://www.ratemyprofessors.com/*",
    "https://cougargrades.io/*",
    "https://unpkg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.uh.edu/*",
        "https://*.unt.edu/*",
        "https://*.utsa.edu/*",
        "https://*.utexas.edu/*",
        "https://*.utdallas.edu/*",
        "https://utdallas.collegescheduler.com/*",
        "https://*.tsu.edu/*",
        "https://*.ec.tsu.edu/*",
        "https://reg-prod.ec.tsu.edu/*",
        "https://*.txstate.edu/*",
        "https://*.ec.txstate.edu/*",
        "https://reg-prod.ec.txstate.edu/*",
        "https://txstate.collegescheduler.com/*"
      ],
      "js": ["contentScript.js"],
      "css": ["ui.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
